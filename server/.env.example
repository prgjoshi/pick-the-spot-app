# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
LOG_LEVEL=info          # debug | info | warn | error

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
# Use the *pooled* connection string for the app (ends with -pooler.xxx.neon.tech)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-hex-64
JWT_EXPIRES_IN=7d

# ── Google Places API ─────────────────────────────────────────────────────────
# Enable "Places API (New)" at: https://console.cloud.google.com/apis
GOOGLE_PLACES_API_KEY=

# ── Redis Cache (optional — Upstash recommended) ──────────────────────────────
# Without this, caching is disabled but the app runs normally.
# Get from: https://console.upstash.com → Create Database → Redis URL
# Use the rediss:// (TLS) URL from the Upstash console.
REDIS_URL=rediss://default:password@region.upstash.io:6379

# ── CORS (production only) ────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
